<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <title>Receipt {{receipt_number}}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, sans-serif; font-size: 13px; color: #2c2c2c; padding: 40px; }
    .header { display: flex; justify-content: space-between; border-bottom: 3px solid #16a34a; padding-bottom: 20px; margin-bottom: 24px; }
    .company-info h1 { font-size: 24px; color: #16a34a; font-weight: 700; }
    .receipt-meta h2 { font-size: 20px; color: #16a34a; text-align: right; }
    .receipt-meta table { margin-left: auto; border: none; }
    .receipt-meta td { padding: 2px 4px; border: none; font-size: 12px; }
    .bill-to { margin-bottom: 24px; }
    .bill-to h3 { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #888; margin-bottom: 6px; }
    .bill-to p { font-weight: 700; font-size: 14px; }
    table.items { width: 100%; border-collapse: collapse; }
    table.items thead tr { background: #16a34a; color: #fff; }
    table.items thead th { padding: 10px 12px; font-size: 12px; border: none; }
    table.items tbody tr { border-bottom: 1px solid #e5e7eb; }
    table.items tbody tr:nth-child(even) { background: #f9fafb; }
    table.items tbody td { padding: 10px 12px; border: none; }
    .right { text-align: right; }
    .total-row { background: #16a34a; color: #fff; padding: 10px 12px; margin-top: 8px; display: flex; justify-content: space-between; font-weight: 700; border-radius: 4px; }
    .summary { display: flex; justify-content: flex-end; margin-top: 0; border-top: 2px solid #e5e7eb; }
    .summary-inner { width: 280px; padding-top: 12px; }
    .srow { display: flex; justify-content: space-between; padding: 4px 12px; }
    .paid-stamp { margin-top: 24px; text-align: center; }
    .paid-stamp span { display: inline-block; border: 3px solid #16a34a; color: #16a34a; font-size: 28px; font-weight: 900; padding: 8px 24px; border-radius: 8px; letter-spacing: 4px; opacity: 0.6; transform: rotate(-10deg); }
    .notes-section { margin-top: 24px; padding: 12px; background: #f0fdf4; border-left: 4px solid #16a34a; }
    .notes-section h4 { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #888; margin-bottom: 4px; }
    .footer { margin-top: 32px; border-top: 1px solid #e5e7eb; padding-top: 12px; display: flex; justify-content: space-between; font-size: 11px; color: #aaa; }
  </style>
</head>
<body>
  <div class="header">
    <div class="company-info">
      <h1>{{#if company_name}}{{company_name}}{{else}}Your Company{{/if}}</h1>
      {{#if company_address}}<p style="color:#666;font-size:12px;margin-top:4px;">{{company_address}}</p>{{/if}}
    </div>
    <div class="receipt-meta">
      <h2>KWITANSI</h2>
      <table>
        <tr><td style="color:#888;text-align:right;">No:</td><td style="font-weight:600;">{{receipt_number}}</td></tr>
        <tr><td style="color:#888;text-align:right;">Tanggal:</td><td>{{formatDate receipt_date}}</td></tr>
        {{#if payment_method}}<tr><td style="color:#888;text-align:right;">Metode:</td><td>{{payment_method}}</td></tr>{{/if}}
      </table>
    </div>
  </div>

  <div class="bill-to">
    <h3>Diterima Dari</h3>
    <p>{{payer_name}}</p>
    {{#if payer_address}}<p style="font-size:12px;color:#555;font-weight:400;">{{payer_address}}</p>{{/if}}
  </div>

  <table class="items">
    <thead>
      <tr>
        <th>#</th>
        <th>Keterangan</th>
        <th class="right">Qty</th>
        <th class="right">Harga</th>
        <th class="right">Total</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr>
        <td style="color:#aaa;width:30px;">{{addOne @index}}</td>
        <td>{{description}}</td>
        <td class="right" style="width:50px;">{{qty}}</td>
        <td class="right" style="width:130px;">{{formatCurrency unit_price}}</td>
        <td class="right" style="width:130px;font-weight:600;">{{multiply qty unit_price}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <div class="summary">
    <div class="summary-inner">
      <div class="srow"><span style="color:#555;">Subtotal</span><span style="font-weight:600;">{{formatCurrency subtotal}}</span></div>
      {{#if tax}}<div class="srow"><span style="color:#555;">Pajak</span><span style="font-weight:600;">{{formatCurrency tax}}</span></div>{{/if}}
      <div class="total-row"><span>TOTAL DIBAYAR</span><span>{{formatCurrency total}}</span></div>
    </div>
  </div>

  <div class="paid-stamp"><span>LUNAS</span></div>

  {{#if notes}}
  <div class="notes-section">
    <h4>Catatan</h4>
    <p>{{notes}}</p>
  </div>
  {{/if}}

  <div class="footer">
    <span>DocGen Engine — Generated automatically</span>
    <span>{{receipt_number}}</span>
  </div>
</body>
</html>
