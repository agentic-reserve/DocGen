<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice {{invoice_number}}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Arial', 'Helvetica Neue', Helvetica, sans-serif;
      font-size: 13px;
      color: #2c2c2c;
      background: #fff;
      padding: 40px;
    }

    /* ── Header ── */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 32px;
      border-bottom: 3px solid #1a56db;
      padding-bottom: 20px;
    }

    .company-info h1 {
      font-size: 26px;
      color: #1a56db;
      letter-spacing: 1px;
      font-weight: 700;
    }

    .company-info p {
      color: #666;
      margin-top: 4px;
      font-size: 12px;
    }

    .invoice-meta {
      text-align: right;
    }

    .invoice-meta h2 {
      font-size: 22px;
      color: #1a56db;
      letter-spacing: 2px;
      text-transform: uppercase;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .invoice-meta table {
      margin-left: auto;
      border: none;
    }

    .invoice-meta table td {
      padding: 2px 4px;
      border: none;
      font-size: 12px;
    }

    .invoice-meta table td:first-child {
      color: #888;
      text-align: right;
    }

    .invoice-meta table td:last-child {
      color: #2c2c2c;
      font-weight: 600;
      text-align: left;
    }

    /* ── Bill To ── */
    .bill-section {
      display: flex;
      justify-content: space-between;
      margin-bottom: 28px;
    }

    .bill-to h3 {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #888;
      margin-bottom: 6px;
    }

    .bill-to p {
      font-size: 14px;
      font-weight: 700;
      color: #1a1a1a;
      margin-bottom: 2px;
    }

    .bill-to .address {
      font-size: 12px;
      color: #555;
      font-weight: 400;
      white-space: pre-line;
    }

    /* ── Status Badge ── */
    .status-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      background: #fef3c7;
      color: #92400e;
      border: 1px solid #fcd34d;
    }

    /* ── Items Table ── */
    table.items {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 0;
    }

    table.items thead tr {
      background: #1a56db;
      color: #fff;
    }

    table.items thead th {
      padding: 10px 12px;
      text-align: left;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.5px;
      border: none;
    }

    table.items thead th.right {
      text-align: right;
    }

    table.items tbody tr {
      border-bottom: 1px solid #e5e7eb;
    }

    table.items tbody tr:nth-child(even) {
      background: #f9fafb;
    }

    table.items tbody td {
      padding: 10px 12px;
      font-size: 13px;
      border: none;
      vertical-align: top;
    }

    table.items tbody td.right {
      text-align: right;
    }

    table.items tbody td.center {
      text-align: center;
    }

    /* ── Summary ── */
    .summary-wrapper {
      display: flex;
      justify-content: flex-end;
      margin-top: 0;
      border-top: 2px solid #e5e7eb;
    }

    .summary {
      width: 320px;
      padding-top: 12px;
    }

    .summary-row {
      display: flex;
      justify-content: space-between;
      padding: 5px 12px;
      font-size: 13px;
    }

    .summary-row .label {
      color: #555;
    }

    .summary-row .value {
      font-weight: 600;
      color: #2c2c2c;
    }

    .summary-row.total {
      background: #1a56db;
      color: #fff;
      border-radius: 4px;
      margin-top: 6px;
      padding: 10px 12px;
      font-size: 15px;
      font-weight: 700;
    }

    .summary-row.total .label,
    .summary-row.total .value {
      color: #fff;
    }

    /* ── Notes ── */
    .notes-section {
      margin-top: 32px;
      padding: 16px;
      background: #f8f9fa;
      border-left: 4px solid #1a56db;
      border-radius: 0 4px 4px 0;
    }

    .notes-section h4 {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #888;
      margin-bottom: 6px;
    }

    .notes-section p {
      font-size: 13px;
      color: #444;
      line-height: 1.5;
    }

    /* ── Footer ── */
    .footer {
      margin-top: 40px;
      padding-top: 16px;
      border-top: 1px solid #e5e7eb;
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: #aaa;
    }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="header">
    <div class="company-info">
      <h1>{{#if company_name}}{{company_name}}{{else}}Your Company{{/if}}</h1>
      {{#if company_address}}<p>{{company_address}}</p>{{/if}}
      {{#if company_email}}<p>{{company_email}}</p>{{/if}}
    </div>

    <div class="invoice-meta">
      <h2>Invoice</h2>
      <table>
        <tr>
          <td>No. Invoice:</td>
          <td>{{invoice_number}}</td>
        </tr>
        <tr>
          <td>Tanggal:</td>
          <td>{{formatDate issue_date}}</td>
        </tr>
        <tr>
          <td>Jatuh Tempo:</td>
          <td>{{formatDate due_date}}</td>
        </tr>
      </table>
    </div>
  </div>

  <!-- Bill To -->
  <div class="bill-section">
    <div class="bill-to">
      <h3>Tagihan Kepada</h3>
      <p>{{client_name}}</p>
      {{#if client_address}}<span class="address">{{client_address}}</span>{{/if}}
    </div>
    <div>
      <span class="status-badge">Belum Dibayar</span>
    </div>
  </div>

  <!-- Items Table -->
  <table class="items">
    <thead>
      <tr>
        <th>#</th>
        <th>Deskripsi</th>
        <th class="right">Qty</th>
        <th class="right">Harga Satuan</th>
        <th class="right">Total</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr>
        <td style="color:#aaa; width: 30px;">{{addOne @index}}</td>
        <td>{{description}}</td>
        <td class="right" style="width: 50px;">{{qty}}</td>
        <td class="right" style="width: 140px;">{{formatCurrency unit_price}}</td>
        <td class="right" style="width: 140px; font-weight: 600;">{{multiply qty unit_price}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <!-- Summary -->
  <div class="summary-wrapper">
    <div class="summary">
      <div class="summary-row">
        <span class="label">Subtotal</span>
        <span class="value">{{formatCurrency subtotal}}</span>
      </div>
      {{#if tax}}
      <div class="summary-row">
        <span class="label">PPN ({{tax_rate}}%)</span>
        <span class="value">{{formatCurrency tax}}</span>
      </div>
      {{/if}}
      {{#if discount}}
      <div class="summary-row">
        <span class="label">Diskon</span>
        <span class="value" style="color: #dc2626;">- {{formatCurrency discount}}</span>
      </div>
      {{/if}}
      <div class="summary-row total">
        <span class="label">TOTAL</span>
        <span class="value">{{formatCurrency total}}</span>
      </div>
    </div>
  </div>

  {{#if notes}}
  <!-- Notes -->
  <div class="notes-section">
    <h4>Catatan</h4>
    <p>{{notes}}</p>
  </div>
  {{/if}}

  <!-- Footer -->
  <div class="footer">
    <span>DocGen Engine — Generated automatically</span>
    <span>{{invoice_number}}</span>
  </div>

</body>
</html>
